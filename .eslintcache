               <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fas fa-desktop\" />\r\n                    <p>\r\n                      Almacen\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <Link to=\"/tblCategoria\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Categoría</p>\r\n                      </Link>\r\n                    </li>\r\n                  </ul>\r\n\r\n                    \r\n\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <Link to=\"/tblArticulo\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Artículos</p>\r\n                      </Link>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n\r\n                <li className=\"nav-item has-treeview\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fa fa-truck\" />\r\n                    <p>\r\n                      Compras\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Ingreso</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Proveedores</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n\r\n                <li className=\"nav-item has-treeview\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fa fa-cart-plus\" />\r\n                    <p>\r\n                      Ventas\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Ingreso</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Proveedores</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n\r\n                <li className=\"nav-item has-treeview\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fa fa-chart-line\" />\r\n                    <p>\r\n                      Consulta Compras\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Ingreso</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Proveedores</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n\r\n                <li className=\"nav-item has-treeview\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fa fa-user\" />\r\n                    <p>\r\n                      Acceso\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <Link to=\"/tblUsuario\" href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Usuario</p>\r\n                      </Link>\r\n                    </li>\r\n                  </ul>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Proveedores</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n\r\n                <li className=\"nav-item has-treeview\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"nav-icon fa fa-chart-line\" />\r\n                    <p>\r\n                      Consulta Ventas\r\n                      <i className=\"fas fa-angle-left right\" />\r\n                    </p>\r\n                  </a>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Ingreso</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  <ul className=\"nav nav-treeview\">\r\n                    <li className=\"nav-item\">\r\n                      <a href=\"!#\" className=\"nav-link\">\r\n                        <i className=\"far fa-circle nav-icon\" />\r\n                        <p>Proveedores</p>\r\n                      </a>\r\n                    </li>\r\n                  </ul>\r\n                  \r\n                </li>\r\n                \r\n                \r\n\r\n            \r\n\r\n\r\n\r\n\r\n\r\n                <li className=\"nav-header\">MULTI LEVEL EXAMPLE</li>\r\n                <li className=\"nav-item\">\r\n                  <a href=\"#\" className=\"nav-link\">\r\n                    <i className=\"fas fa-circle nav-icon\" />\r\n                    <p>Level 1</p>\r\n                  </a>\r\n                </li>\r\n              </ul>\r\n            </nav>\r\n            {/* /.sidebar-menu */}\r\n          </div>\r\n          {/* /.sidebar */}\r\n        </aside>\r\n      </div>\r\n    )\r\n  }\r\n}\r\n","D:\\workspace\\pos_front\\src\\components\\Articulo\\AddArticulo.jsx",["101","102","103","104","105","106","107"],"D:\\workspace\\pos_front\\src\\components\\Usuario\\ReactPdfPrintUsuario.jsx",["108"],"\r\nimport React, { useRef } from 'react'\r\nimport { useReactToPrint } from 'react-to-print'\r\nimport { useEffect, useState } from 'react'\r\nimport axios from 'axios';\r\nimport { Link, useNavigate } from \"react-router-dom\";\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\nconst ReactPdfPrintUsuario = () => {\r\n    const componentRef = useRef();\r\n\r\n    const handlePrint = useReactToPrint({\r\n        content: () => componentRef.current,\r\n        documentTitle: 'Listado de Usuario',\r\n        //onAfterPrint:()=>alert('Print success')\r\n    })\r\n\r\n    const [Usuario, setUsuario] = useState([])\r\n\r\n    const cargarUsuario = async () => {\r\n        const response = await axios.get(`${baseUrl}/Persona/all`)\r\n        setUsuario(response.data.data)\r\n    \r\n      }\r\n      useEffect(() => {\r\n        cargarUsuario();\r\n      }, []);\r\n\r\n    return (\r\n        <>\r\n            <div ref={componentRef} style={{ width: '100%', height: window.innerHeight }}>\r\n                <h1 className=\"text-center my-3 border py-2 \">\r\n                    Datos Usuarios \r\n                    <button type=\"button\" className=\"btn btn-sm btn-outline-secondary px-3 m-2\" onClick={handlePrint}>Imprimir</button>\r\n                    <Link className=\"btn btn-sm btn-outline-danger px-3 \" to=\"/tblUsuario\"> cancelar</Link>\r\n                </h1>\r\n                <table className='w-75 mx-auto table table-striped' >\r\n                    <thead>\r\n                        <th>Código</th>\r\n                        <th>Tipo Persona</th>\r\n                        <th>Tipo Documento</th>\r\n                        <th>nombre</th>\r\n                        <th>no_documento</th>\r\n                        <th>direccion</th>\r\n                        <th>telefono</th>\r\n                        <th>correo</th>\r\n                    </thead>\r\n                    <tbody>\r\n                        {Usuario.map((item, i)=>{\r\n                            return(\r\n                                <tr key={item.id}>\r\n                                    <td>{item.id}</td>\r\n                                    <td>{item.tipo_persona}</td>\r\n                                    <td>{item.tipo_documento}</td>\r\n                                    <td>{item.nombre}</td>\r\n                                    <td>{item.no_documento}</td>\r\n                                    <td>{item.direccion}</td>\r\n                                    <td>{item.telefono}</td>\r\n                                    <td>{item.correo}</td>\r\n\r\n                                </tr>\r\n                            )      \r\n                        })\r\n                        }\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n            \r\n        </>\r\n    )\r\n}\r\n\r\nexport default ReactPdfPrintUsuario\r\n","D:\\workspace\\pos_front\\src\\components\\Categoria\\ReactPdfPrint.jsx",["109"],"\r\nimport React, { useRef } from 'react'\r\nimport { useReactToPrint } from 'react-to-print'\r\nimport { useEffect, useState } from 'react'\r\nimport axios from 'axios';\r\nimport { Link, useNavigate } from \"react-router-dom\";\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\nconst ReactPdfPrint = () => {\r\n    const componentRef = useRef();\r\n\r\n    const handlePrint = useReactToPrint({\r\n        content: () => componentRef.current,\r\n        documentTitle: 'Listado de Categoria',\r\n        //onAfterPrint:()=>alert('Print success')\r\n    })\r\n\r\n    const [Categoria, setCategoria] = useState([])\r\n\r\n    const cargarCategoria = async () => {\r\n        const response = await axios.get(`${baseUrl}/all`)\r\n        setCategoria(response.data.data)\r\n    \r\n      }\r\n      useEffect(() => {\r\n        cargarCategoria();\r\n      }, []);\r\n\r\n    return (\r\n        <>\r\n            <div ref={componentRef} style={{ width: '100%', height: window.innerHeight }}>\r\n                <h1 className=\"text-center my-3 border py-2 \">\r\n                    Datos Categorias \r\n                    <button type=\"button\" className=\"btn btn-sm btn-outline-secondary px-3 m-2\" onClick={handlePrint}>Imprimir</button>\r\n                    <Link className=\"btn btn-sm btn-outline-danger px-3 \" to=\"/tblCategoria\"> cancelar</Link>\r\n                </h1>\r\n                <table className='w-75 mx-auto table table-striped' >\r\n                    <thead>\r\n                        <th>Id</th>\r\n                        <th>Nombre</th>\r\n                        <th>Descripción</th>\r\n                        <th>condición</th>\r\n                    </thead>\r\n                    <tbody>\r\n                        {Categoria.map((item, i)=>{\r\n                            return(\r\n                                <tr key={item.id}>\r\n                                    <td>{item.id}</td>\r\n                                    <td>{item.nombre}</td>\r\n                                    <td>{item.descripcion}</td>\r\n                                    <td>{item.condicion}</td>\r\n\r\n                                </tr>\r\n                            )      \r\n                        })\r\n                        }\r\n                    </tbody>\r\n                </table>\r\n            </div>\r\n            \r\n        </>\r\n    )\r\n}\r\n\r\nexport default ReactPdfPrint\r\n","D:\\workspace\\pos_front\\src\\components\\Usuario\\AddUsuario.jsx",[],"D:\\workspace\\pos_front\\src\\firebaseConfig.js",[],"D:\\workspace\\pos_front\\src\\index.js",[],"D:\\workspace\\pos_front\\src\\reportWebVitals.js",[],"D:\\workspace\\pos_front\\src\\Layout\\Contenido.js",["110","111"],"import React, { Component } from 'react'\r\nimport { Route, Routes } from 'react-router-dom'\r\nimport AddCategoria from '../components/Categoria/AddCategoria'\r\nimport EditCategoria from '../components/Categoria/EditCategoria'\r\nimport ReactPdfPrint from '../components/Categoria/ReactPdfPrint'\r\n\r\nimport TblCategoria from '../components/Categoria/TblCategoria'\r\nimport TblArticulo from '../components/Articulo/TblArticulo'\r\n\r\n\r\nimport Menu from './Menu'\r\nimport Tablero from './Tablero'\r\nimport AddArticulo from '../components/Articulo/AddArticulo'\r\nimport TblUsuario from '../components/Usuario/TblUsuario'\r\nimport AddUsuario from '../components/Usuario/AddUsuario'\r\nimport EditUsuario from '../components/Usuario/EditUsuario'\r\nimport ReactPdfPrintUsuario from '../components/Usuario/ReactPdfPrintUsuario'\r\n\r\n\r\n\r\n\r\nexport default class Contenido extends Component {\r\n    render() {\r\n        return (\r\n            <>\r\n  <div className=\"content-wrapper\">\r\n    {/* Content Header (Page header) */}\r\n    <div className=\"content-header\">\r\n      <div className=\"container-fluid\">\r\n        <div className=\"row mb-2\">\r\n          <div className=\"col-md-12\">\r\n            <h5 className=\"m-0 text-dark\">Contenido Principal</h5>\r\n\r\n            <div className=\"col-sm-12\">\r\n            <ol className=\"breadcrumb float-sm-right \">\r\n              <li className=\"breadcrumb-item\"><a href=\"#\">Home</a></li>\r\n              <li className=\"breadcrumb-item active\">Dashboard v1</li>\r\n            </ol>\r\n          </div>{/* /.col */}\r\n            \r\n            <div className='my-5'></div>\r\n            <div className='container-fluid'>\r\n          \r\n               <Routes>\r\n               <Route exact path='/' element={<Tablero/>}/>\r\n               <Route exact path='/tablero' element={<Tablero/>}></Route>\r\n\r\n\r\n               <Route exact path='/tblCategoria' element={<TblCategoria/>}></Route>\r\n               <Route exact path='/addCategoria' element={<AddCategoria/>}></Route>\r\n               <Route exact path='/editCategoria/:id' element={<EditCategoria/>}></Route>\r\n\r\n\r\n               <Route exact path='/tblArticulo' element={<TblArticulo/>}></Route>\r\n               <Route exact path='/addArticulo' element={<AddArticulo/>}></Route>\r\n               \r\n\r\n               <Route exact path='/tblUsuario' element={<TblUsuario/>}></Route>\r\n               <Route exact path='/addUsuario' element={<AddUsuario/>}></Route>\r\n               <Route exact path='/editUsuario/:id' element={<EditUsuario/>}></Route>\r\n\r\n              \r\n               \r\n               <Route exact path='/reporteCategoria' element={<ReactPdfPrint/>}></Route>\r\n               <Route exact path='/reporteUsuario' element={<ReactPdfPrintUsuario/>}></Route>\r\n\r\n\r\n               \r\n               \r\n\r\n\r\n            </Routes>\r\n\r\n\r\n               \r\n              \r\n\r\n            </div>\r\n            \r\n          </div>{/* /.col */}\r\n          \r\n        </div>{/* /.row */}\r\n      </div>{/* /.container-fluid */}\r\n    </div>\r\n    {/* /.content-header */}\r\n \r\n    \r\n\r\n  </div>\r\n</>\r\n\r\n        )\r\n    }\r\n}\r\n","D:\\workspace\\pos_front\\src\\Layout\\Footer.js",[],"D:\\workspace\\pos_front\\src\\Layout\\Header.js",["112","113","114","115","116","117","118","119","120","121","122","123","124"],"import React, { Component } from 'react'\r\n\r\nexport default class Header extends Component {\r\n    render() {\r\n        return (\r\n           <div>\r\n  <nav className=\"main-header navbar navbar-expand navbar-white navbar-light\">\r\n    {/* Left navbar links */}\r\n    <ul className=\"navbar-nav\">\r\n      <li className=\"nav-item\">\r\n        <a className=\"nav-link\" data-widget=\"pushmenu\" href=\"#\"><i className=\"fas fa-bars\" /></a>\r\n      </li>\r\n      <li className=\"nav-item d-none d-sm-inline-block\">\r\n        <a href=\"index3.html\" className=\"nav-link\">Home</a>\r\n      </li>\r\n      <li className=\"nav-item d-none d-sm-inline-block\">\r\n        <a href=\"#\" className=\"nav-link\">Contact</a>\r\n      </li>\r\n    </ul>\r\n    {/* SEARCH FORM */}\r\n    <form className=\"form-inline ml-3\">\r\n      <div className=\"input-group input-group-sm\">\r\n        <input className=\"form-control form-control-navbar\" type=\"search\" placeholder=\"Search\" aria-label=\"Search\" />\r\n        <div className=\"input-group-append\">\r\n          <button className=\"btn btn-navbar\" type=\"submit\">\r\n            <i className=\"fas fa-search\" />\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </form>\r\n    {/* Right navbar links */}\r\n    <ul className=\"navbar-nav ml-auto\">\r\n      {/* Messages Dropdown Menu */}\r\n      <li className=\"nav-item dropdown\">\r\n        <a className=\"nav-link\" data-toggle=\"dropdown\" href=\"#\">\r\n          <i className=\"far fa-comments\" />\r\n          <span className=\"badge badge-danger navbar-badge\">3</span>\r\n        </a>\r\n        <div className=\"dropdown-menu dropdown-menu-lg dropdown-menu-right\">\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            {/* Message Start */}\r\n            <div className=\"media\">\r\n              <img src=\"dist/img/user1-128x128.jpg\" alt=\"User Avatar\" className=\"img-size-50 mr-3 img-circle\" />\r\n              <div className=\"media-body\">\r\n                <h3 className=\"dropdown-item-title\">\r\n                  Brad Diesel\r\n                  <span className=\"float-right text-sm text-danger\"><i className=\"fas fa-star\" /></span>\r\n                </h3>\r\n                <p className=\"text-sm\">Call me whenever you can...</p>\r\n                <p className=\"text-sm text-muted\"><i className=\"far fa-clock mr-1\" /> 4 Hours Ago</p>\r\n              </div>\r\n            </div>\r\n            {/* Message End */}\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            {/* Message Start */}\r\n            <div className=\"media\">\r\n              <img src=\"dist/img/user8-128x128.jpg\" alt=\"User Avatar\" className=\"img-size-50 img-circle mr-3\" />\r\n              <div className=\"media-body\">\r\n                <h3 className=\"dropdown-item-title\">\r\n                  John Pierce\r\n                  <span className=\"float-right text-sm text-muted\"><i className=\"fas fa-star\" /></span>\r\n                </h3>\r\n                <p className=\"text-sm\">I got your message bro</p>\r\n                <p className=\"text-sm text-muted\"><i className=\"far fa-clock mr-1\" /> 4 Hours Ago</p>\r\n              </div>\r\n            </div>\r\n            {/* Message End */}\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            {/* Message Start */}\r\n            <div className=\"media\">\r\n              <img src=\"dist/img/user3-128x128.jpg\" alt=\"User Avatar\" className=\"img-size-50 img-circle mr-3\" />\r\n              <div className=\"media-body\">\r\n                <h3 className=\"dropdown-item-title\">\r\n                  Nora Silvester\r\n                  <span className=\"float-right text-sm text-warning\"><i className=\"fas fa-star\" /></span>\r\n                </h3>\r\n                <p className=\"text-sm\">The subject goes here</p>\r\n                <p className=\"text-sm text-muted\"><i className=\"far fa-clock mr-1\" /> 4 Hours Ago</p>\r\n              </div>\r\n            </div>\r\n            {/* Message End */}\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item dropdown-footer\">See All Messages</a>\r\n        </div>\r\n      </li>\r\n      {/* Notifications Dropdown Menu */}\r\n      <li className=\"nav-item dropdown\">\r\n        <a className=\"nav-link\" data-toggle=\"dropdown\" href=\"#\">\r\n          <i className=\"far fa-bell\" />\r\n          <span className=\"badge badge-warning navbar-badge\">15</span>\r\n        </a>\r\n        <div className=\"dropdown-menu dropdown-menu-lg dropdown-menu-right\">\r\n          <span className=\"dropdown-item dropdown-header\">15 Notifications</span>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            <i className=\"fas fa-envelope mr-2\" /> 4 new messages\r\n            <span className=\"float-right text-muted text-sm\">3 mins</span>\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            <i className=\"fas fa-users mr-2\" /> 8 friend requests\r\n            <span className=\"float-right text-muted text-sm\">12 hours</span>\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item\">\r\n            <i className=\"fas fa-file mr-2\" /> 3 new reports\r\n            <span className=\"float-right text-muted text-sm\">2 days</span>\r\n          </a>\r\n          <div className=\"dropdown-divider\" />\r\n          <a href=\"#\" className=\"dropdown-item dropdown-footer\">See All Notifications</a>\r\n        </div>\r\n      </li>\r\n      <li className=\"nav-item\">\r\n        <a className=\"nav-link\" data-widget=\"control-sidebar\" data-slide=\"true\" href=\"#\">\r\n          <i className=\"fas fa-th-large\" />\r\n        </a>\r\n      </li>\r\n    </ul>\r\n  </nav>\r\n</div>\r\n\r\n        )\r\n    }\r\n}\r\n","D:\\workspace\\pos_front\\src\\Layout\\Tablero.jsx",["125","126","127"],"import React from 'react'\r\n\r\nconst Tablero = () => {\r\n  return (\r\n    <>\r\n       {/* Main content */}\r\n    <section className=\"content\">\r\n      <div className=\"container-fluid\">\r\n        {/* Small boxes (Stat box) */}\r\n        <div className=\"row\">\r\n          <div className=\"col-lg-3 col-6\">\r\n            {/* small box */}\r\n            <div className=\"small-box bg-info\">\r\n              <div className=\"inner\">\r\n                <h3>150</h3>\r\n                <p>New Orders</p>\r\n              </div>\r\n              <div className=\"icon\">\r\n                <i className=\"ion ion-bag\" />\r\n              </div>\r\n              <a href=\"#\" className=\"small-box-footer\">More info <i className=\"fas fa-arrow-circle-right\" /></a>\r\n            </div>\r\n          </div>\r\n          {/* ./col */}\r\n          <div className=\"col-lg-3 col-6\">\r\n            {/* small box */}\r\n            <div className=\"small-box bg-success\">\r\n              <div className=\"inner\">\r\n                <h3>53<sup style={{fontSize: 20}}>%</sup></h3>\r\n                <p>Bounce Rate</p>\r\n              </div>\r\n              <div className=\"icon\">\r\n                <i className=\"ion ion-stats-bars\" />\r\n              </div>\r\n              <a href=\"#\" className=\"small-box-footer\">More info <i className=\"fas fa-arrow-circle-right\" /></a>\r\n            </div>\r\n          </div>\r\n          {/* ./col */}\r\n          <div className=\"col-lg-3 col-6\">\r\n            {/* small box */}\r\n            <div className=\"small-box bg-warning\">\r\n              <div className=\"inner\">\r\n                <h3>44</h3>\r\n                <p>User Registrations</p>\r\n              </div>\r\n              <div className=\"icon\">\r\n                <i className=\"ion ion-person-add\" />\r\n              </div>\r\n              <a href=\"#\" className=\"small-box-footer\">More info <i className=\"fas fa-arrow-circle-right\" /></a>\r\n            </div>\r\n          </div>\r\n          \r\n        </div>\r\n       \r\n      </div>{/* /.container-fluid */}\r\n    </section>\r\n    {/* /.content */}\r\n\r\n\r\n    </>\r\n  )\r\n}\r\n\r\nexport default Tablero\r\n","D:\\workspace\\pos_front\\src\\components\\Articulo\\TblArticulo.jsx",["128","129","130"],"import 'styled-components'\r\nimport axios from 'axios'\r\nimport React, { useEffect, useState } from 'react'\r\nimport DataTable, { createTheme } from 'react-data-table-component'\r\nimport { Link, useParams } from 'react-router-dom'\r\nimport Swal from 'sweetalert2'\r\nimport { CSVLink } from 'react-csv'\r\n\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\n\r\n\r\nconst TblArticulo = () => {\r\n  const [search, setSearch] = useState('')\r\n  const [Articulo, setArticulo] = useState([])\r\n  const [filteredArticulo, setFilteredArticulo] = useState([])\r\n\r\n  useEffect(() => {\r\n    cargarArticulo();\r\n  }, []);\r\n\r\n  const cargarArticulo = async () => {\r\n\r\n    const response = await axios.get(`${baseUrl}/Articulo/all`)\r\n    setArticulo(response.data.data)\r\n    setFilteredArticulo(response.data.data)\r\n\r\n  }\r\n\r\n\r\n  const deleteArticulo = async (id) => {\r\n    await axios.delete(`${baseUrl}/Articulo/${id}`)\r\n    cargarArticulo()\r\n  }\r\n\r\n  function confirmar(id, nombre) {\r\n    Swal.fire({\r\n      title: '¿Confirma eliminar el registro: ' + nombre + '?',\r\n      icon: 'warning',\r\n      showCancelButton: true,\r\n      confirmButtonColor: '#d33',\r\n      cancelButtonColor: '#6c757d',\r\n      confirmButtonText: 'Confirmar'\r\n\r\n    }).then((result) => {\r\n      if (result.isConfirmed) {\r\n        deleteArticulo(id)\r\n\r\n      }\r\n    });\r\n  };\r\n\r\n\r\n  const columns = [\r\n    \r\n    {\r\n      name: 'Nombre',\r\n      selector: (row) => row.nombre,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Categoría',\r\n      selector: (row) => row.categoria.nombre,\r\n    },\r\n    {\r\n      name: 'Código',\r\n      selector: (row) => row.codigo,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Existencia',\r\n      selector: (row) => row.existencia,\r\n    },\r\n   \r\n    {\r\n      name: 'Imagen',\r\n      selector: (row) => <img width={50} height={50} src={row.imagen} />,\r\n    },\r\n    {\r\n      name: 'Estado',\r\n      selector: (row) => row.categoria.condicion,\r\n    },\r\n    {\r\n      name: 'Opciones',\r\n      cell: (row) => [\r\n        <Link\r\n          className=\"btn btn-outline-primary mx-1\"\r\n          to={`/editCategoria/${row.id}`}\r\n        >\r\n          <span className=\"fa-solid fa-pen-to-square\"></span>\r\n        </Link>,\r\n        <button\r\n          className=\"btn btn-danger mx-1\"\r\n          onClick={() => confirmar(row.id,row.nombre)}>\r\n          <span className=\"fa-regular fa-trash-can\"></span>\r\n        </button>,\r\n      ],\r\n    },\r\n\r\n  ]\r\n\r\n  useEffect(() => {\r\n    const result = Articulo.filter((country) => {\r\n      return country.nombre.toLowerCase().match(search.toLowerCase())\r\n    })\r\n\r\n    setFilteredArticulo(result)\r\n  }, [Articulo, search])\r\n\r\n  return (\r\n    <div className='container-fluid ' >\r\n      <DataTable className='table border table-responsive  '\r\n        defaultSortField=\"idTablaData\"\r\n        title=\"Listado de Articulo\"\r\n        columns={columns}\r\n        data={filteredArticulo}\r\n        pagination\r\n        sortIcon={<i className=\"fa-solid fa-sort\"></i>}\r\n        fixedHeader\r\n        fixedHeaderScrollHeight=\"450px\"\r\n        selectableRowsHighlight\r\n        highlightOnHover\r\n        actions={[\r\n          <Link className=\"btn btn-sm btn-primary px-5\" to=\"/addArticulo\"> Agregar Articulo</Link>,\r\n          <Link className=\"btn btn-sm btn-outline-secondary px-3\" to=\"/reporteArticulo\"> PDF</Link>,\r\n          <CSVLink data={filteredArticulo} filename={\"Tabla de Articulo.csv\"}><button className=\"btn btn-sm btn-outline-secondary px-3\"> CSV</button></CSVLink>,\r\n        ]}\r\n        subHeader\r\n        subHeaderComponent={\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Buscar Articulo\"\r\n            className=\"w-25 form-control\"\r\n            value={search}\r\n            onChange={(e) => setSearch(e.target.value)}\r\n          />\r\n        }\r\n      />\r\n    </div>\r\n  )\r\n}\r\nexport default TblArticulo\r\n","D:\\workspace\\pos_front\\src\\components\\Categoria\\AddCategoria.jsx",[],"D:\\workspace\\pos_front\\src\\components\\Usuario\\EditUsuario.jsx",["131"],"\r\nimport axios from \"axios\";\r\nimport React, { useEffect, useState } from \"react\";\r\nimport { Link, useNavigate, useParams } from \"react-router-dom\";\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\nconst EditUsuario = () => {\r\n\r\nlet navigate = useNavigate();\r\n\r\nconst { id } = useParams()\r\n\r\nconst [Usuario, setUsuario] = useState({\r\n  tipo_persona: \"\",\r\n  tipo_documento: \"\",\r\n  nombre: \"\",\r\n  no_documento: \"\",\r\n  direccion: \"\",\r\n  telefono: \"\",\r\n  correo: \"\",\r\n})\r\n\r\nconst { tipo_persona, tipo_documento, nombre, no_documento, direccion, telefono, correo } = Usuario;\r\n\r\nconst onInputChange = (e) => {\r\n  setUsuario({ ...Usuario, [e.target.name]: e.target.value });\r\n};\r\n\r\nuseEffect(() => {\r\n  cargarUsuario()\r\n}, []);\r\n\r\n\r\n\r\nconst onSubmit = async (e) => {\r\n  e.preventDefault();\r\n  await axios.put(`${baseUrl}/Persona`, Usuario);\r\n  navigate(\"/tblUsuario\");\r\n};\r\n\r\nconst cargarUsuario = async () => {\r\n  const response = await axios.get(`${baseUrl}/Persona/id/${id}`)\r\n  console.log(response.data.data[0])\r\n  setUsuario(response.data.data[0])\r\n}\r\n\r\n  return (\r\n    <div className=\"container\">\r\n    <div className=\"row justify-content-center\">\r\n    <h2 className=\"text-center m-4\">Editar de Usuarios</h2>\r\n      <div className=\"col-12 col-lg-9\">\r\n        <section className />\r\n        <div className=\"clas \" />\r\n        <form action className=\"bg-light my-3 p-3 border rounded\" onSubmit={(e) => onSubmit(e)}>\r\n      \r\n          <div className=\"form-row mb-4\">\r\n           \r\n            <div className=\"form-group col-12 col-sm-12\">\r\n              <label htmlFor=\"nombre\">Nombre(*):</label>\r\n              <input type=\"text\" name=\"nombre\" id=\"nombre\" className=\"form-control\" placeholder=\"Nombre de Usuario\"\r\n               value={nombre} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n           \r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"tipo_documento\">Tipo Documento(*):</label>\r\n              <input type=\"text\" name=\"tipo_documento\" id=\"tipo_documento\" className=\"form-control\" \r\n               value={tipo_documento} onChange={(e)=>onInputChange(e)}/>\r\n            \r\n            </div>\r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"no_documento\">No_Documento(*):</label>\r\n              <input type=\"text\" name=\"no_documento\" id=\"no_documento\" className=\"form-control\" \r\n              value={no_documento} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n\r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"direccion\">Dirección:</label>\r\n              <input type=\"text\" name=\"direccion\" id=\"direccion\" className=\"form-control\" \r\n              value={direccion} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"telefono\">Teléfono:</label>\r\n              <input type=\"tel\" name=\"telefono\" id=\"telefono\" className=\"form-control\"\r\n              value={telefono} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n\r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"tipo_persona\">Tipo Persona:</label>\r\n              <input type=\"text\" name=\"tipo_persona\" id=\"tipo_persona\" className=\"form-control\"\r\n              value={tipo_persona} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n            <div className=\"form-group col-12 col-sm-6\">\r\n              <label htmlFor=\"correo\">Email:</label>\r\n              <input type=\"email\" name=\"correo\" id=\"correo\" className=\"form-control\"\r\n              value={correo} onChange={(e)=>onInputChange(e)}/>\r\n            </div>\r\n          </div>      \r\n          <button type=\"submit\" className=\"btn btn-outline-primary\">Guardar Usuario</button>\r\n          <Link className=\"btn btn-outline-danger mx-2\" to=\"/tblUsuario\">Cancelar</Link>\r\n        </form>\r\n      </div>\r\n    </div>\r\n  </div>\r\n    \r\n  );\r\n}\r\n\r\nexport default EditUsuario","D:\\workspace\\pos_front\\src\\components\\Usuario\\TblUsuario.jsx",["132","133"],"import 'styled-components'\r\nimport axios from 'axios'\r\nimport React, { useEffect, useState } from 'react'\r\nimport DataTable, { createTheme } from 'react-data-table-component'\r\nimport { Link, useParams } from 'react-router-dom'\r\nimport Swal from 'sweetalert2'\r\nimport { CSVLink } from 'react-csv'\r\n\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\n\r\n\r\nconst TblUsuario = () => {\r\n  const [search, setSearch] = useState('')\r\n  const [Usuario, setUsuario] = useState([])\r\n  const [filteredUsuario, setFilteredUsuario] = useState([])\r\n\r\n  useEffect(() => {\r\n    cargarUsuario();\r\n  }, []);\r\n\r\n  const cargarUsuario = async () => {\r\n\r\n    const response = await axios.get(`${baseUrl}/Persona/all`)\r\n    setUsuario(response.data.data)\r\n    setFilteredUsuario(response.data.data)\r\n\r\n  }\r\n\r\n\r\n  const deleteUsuario = async (id) => {\r\n    await axios.delete(`${baseUrl}/Persona/id/${id}`)\r\n    cargarUsuario()\r\n  }\r\n\r\n  function confirmar(id, nombre) {\r\n    Swal.fire({\r\n      title: '¿Confirma eliminar el registro: ' + nombre + '?',\r\n      icon: 'warning',\r\n      showCancelButton: true,\r\n      confirmButtonColor: '#d33',\r\n      cancelButtonColor: '#6c757d',\r\n      confirmButtonText: 'Confirmar'\r\n\r\n    }).then((result) => {\r\n      if (result.isConfirmed) {\r\n        deleteUsuario(id)\r\n\r\n      }\r\n    });\r\n  };\r\n\r\n\r\n  const columns = [\r\n    {\r\n      name: 'Código',\r\n      selector: (row) => row.id,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Tipo Persona',\r\n      selector: (row) => row.tipo_persona,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Tipo Documento',\r\n      selector: (row) => row.tipo_documento,\r\n      sortable: true,\r\n\r\n    },\r\n    {\r\n      name: 'Nombre',\r\n      selector: (row) => row.nombre,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Dirección',\r\n      selector: (row) => row.direccion,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Telefono',\r\n      selector: (row) => row.telefono,\r\n      sortable: true,\r\n    },\r\n    {\r\n      name: 'Correo',\r\n      selector: (row) => row.correo,\r\n      sortable: true,\r\n    },\r\n\r\n\r\n    {\r\n      name: 'Opciones',\r\n      cell: (row) => [\r\n        <Link\r\n          className=\"btn btn-outline-primary mx-1\"\r\n          to={`/editUsuario/${row.id}`}\r\n\r\n        >\r\n          <span className=\"fa-solid fa-pen-to-square\"></span>\r\n\r\n        </Link>,\r\n\r\n        <button\r\n          className=\"btn btn-danger mx-1\"\r\n          onClick={() => confirmar(row.id, row.nombre)}>\r\n          <span className=\"fa-regular fa-trash-can\"></span>\r\n        </button>,\r\n\r\n      ],\r\n    },\r\n  ]\r\n\r\n\r\n  useEffect(() => {\r\n    const result = Usuario.filter((usuario) => {\r\n      return usuario.nombre.toLowerCase().match(search.toLowerCase())\r\n    })\r\n\r\n    setFilteredUsuario(result)\r\n  }, [Usuario, search])\r\n\r\n  return (\r\n    <div className='container-fluid ' >\r\n      <DataTable className='table border table-responsive  '\r\n        defaultSortField=\"idTablaData\"\r\n        title=\"Listado de Usuarios\"\r\n        theme='custom'\r\n        columns={columns}\r\n        data={filteredUsuario}\r\n        pagination\r\n        sortIcon={<i className=\"fa-solid fa-sort\"></i>}\r\n        fixedHeader\r\n        fixedHeaderScrollHeight=\"450px\"\r\n        // selectableRows\r\n        selectableRowsHighlight\r\n        highlightOnHover\r\n        actions={[\r\n          <Link className=\"btn btn-sm btn-primary px-5\" to=\"/addUsuario\"> Agregar Usuario</Link>,\r\n          <Link className=\"btn btn-sm btn-outline-secondary px-3\" to=\"/reporteUsuario\"> PDF</Link>,\r\n          <CSVLink data={filteredUsuario} filename={\"Tabla de Usuario.csv\"}><button className=\"btn btn-sm btn-outline-secondary px-3\"> CSV</button></CSVLink>,\r\n        ]}\r\n        subHeader\r\n        subHeaderComponent={\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Buscar Usuario\"\r\n\r\n            // className=\"form-control\"\r\n            className=\"w-25 form-control\"\r\n\r\n            value={search}\r\n            onChange={(e) => setSearch(e.target.value)}\r\n          />\r\n        }\r\n      />\r\n    </div>\r\n  )\r\n}\r\nexport default TblUsuario\r\n","D:\\workspace\\pos_front\\src\\components\\Categoria\\EditCategoria.jsx",["134"],"\r\nimport axios from \"axios\";\r\nimport React, { useEffect, useState } from \"react\";\r\nimport { Link, useNavigate, useParams } from \"react-router-dom\";\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\nconst EditCategoria = () => {\r\n  let navigate = useNavigate();\r\n\r\n  const { id } = useParams()\r\n\r\n  const [categoria, setcategoria] = useState({\r\n    nombre: \"\",\r\n    descripcion: \"\",\r\n    condicion: \"\",\r\n  })\r\n\r\n  const { nombre, descripcion, condicion } = categoria;\r\n\r\n  const onInputChange = (e) => {\r\n    setcategoria({ ...categoria, [e.target.name]: e.target.value });\r\n  };\r\n\r\n  useEffect(() => {\r\n    cargarcategoria()\r\n  }, []);\r\n\r\n\r\n  const onSubmit = async (e) => {\r\n    e.preventDefault();\r\n    await axios.put(`${baseUrl}/categoria`, categoria);\r\n    navigate(\"/tblCategoria\");\r\n  };\r\n\r\n\r\n  const cargarcategoria = async () => {\r\n    const response = await axios.get(`${baseUrl}/categoria/${id}`)\r\n    console.log(response.data.data[0])\r\n    setcategoria(response.data.data[0])\r\n  }\r\n\r\n  return (\r\n    <div className=\"container\">\r\n      <div className=\"row\">\r\n        <div className=\"col-md-6 offset-md-3 border rounded p-4 mt-2 shadow\">\r\n          <h2 className=\"text-center m-4\">Editar categoria</h2>\r\n          <form onSubmit={(e) => onSubmit(e)}>\r\n            <div className=\"mb-3\">\r\n              <label htmlFor=\"Nombre\" className=\"form-label\">Nombre</label>\r\n              <input type={\"text\"} className=\"form-control\" \r\n                name=\"nombre\" value={nombre} onChange={(e) => onInputChange(e)} \r\n              />\r\n            </div>\r\n            <div className=\"mb-3\">\r\n              <label htmlFor=\"Descripcion\" className=\"form-label\">Descripcion</label>\r\n              <input type={\"text\"} className=\"form-control\" \r\n              name=\"descripcion\" value={descripcion} onChange={(e) => onInputChange(e)} \r\n              />\r\n            </div>\r\n            <div className=\"mb-3\">\r\n              <label htmlFor=\"condicion\" className=\"form-label\">condicion</label>\r\n              <input type={\"text\"} className=\"form-control\" \r\n              name=\"condicion\" value={condicion} onChange={(e) => onInputChange(e)}/>\r\n            </div>\r\n            <button type=\"submit\" className=\"btn btn-outline-primary\">Guardar</button>\r\n            <Link className=\"btn btn-outline-danger mx-2\" to=\"/tblCategoria\">Cancelar</Link>\r\n          </form>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default EditCategoria","D:\\workspace\\pos_front\\src\\components\\Categoria\\TblCategoria.jsx",["135","136"],"import 'styled-components'\r\nimport axios from 'axios'\r\nimport React, { useEffect, useState } from 'react'\r\nimport DataTable, { createTheme } from 'react-data-table-component'\r\nimport { Link, useParams } from 'react-router-dom'\r\nimport Swal from 'sweetalert2'\r\nimport { CSVLink } from 'react-csv'\r\n\r\n\r\nconst baseUrl = process.env.REACT_APP_BASE_URL\r\n\r\n\r\n\r\nconst TblCategoria = () => {\r\n  const [search, setSearch] = useState('')\r\n  const [Categoria, setCategoria] = useState([])\r\n  const [filteredCategoria, setFilteredCategoria] = useState([])\r\n\r\n  useEffect(() => {\r\n    cargarCategoria();\r\n  }, []);\r\n\r\n  const cargarCategoria = async () => {\r\n\r\n    const response = await axios.get(`${baseUrl}/all`)\r\n    setCategoria(response.data.data)\r\n    setFilteredCategoria(response.data.data)\r\n\r\n  }\r\n\r\n\r\n  const deleteCategoria = async (id) => {\r\n    await axios.delete(`${baseUrl}/categoria/${id}`)\r\n    cargarCategoria()\r\n  }\r\n\r\n  function confirmar(id,nombre) {\r\n    Swal.fire({\r\n      title: '¿Confirma eliminar el registro: ' + nombre + '?',\r\n      icon: 'warning',\r\n      showCancelButton: true,\r\n      confirmButtonColor: '#d33',\r\n      cancelButtonColor: '#6c757d',\r\n      confirmButtonText: 'Confirmar'\r\n      \r\n    }).then((result) => {\r\n      if (result.isConfirmed) {\r\n        deleteCategoria(id)\r\n\r\n      }\r\n    });\r\n  };\r\n\r\n\r\n  const columns = [\r\n    {\r\n      name: 'Código',\r\n      selector: (row) => row.id,\r\n      sortable: true,\r\n\r\n\r\n    },\r\n    {\r\n      name: 'Nombre',\r\n      selector: (row) => row.nombre,\r\n      sortable: true,\r\n\r\n\r\n    },\r\n    {\r\n      name: 'Descripcion',\r\n      selector: (row) => row.descripcion,\r\n      sortable: true,\r\n      // grow:3 fila mas grande que las demas\r\n    },\r\n\r\n    {\r\n      name: 'condicion',\r\n      selector: (row) => row.condicion,\r\n      sortable: true,\r\n      grow:0.5,\r\n      conditionalCellStyles:[\r\n        {\r\n            when: row => row.condicion === 'Activo',\r\n            classNames: ['badge badge-pill badge-success m-3 mb-3'],\r\n        },\r\n        {\r\n          when: row => row.condicion !== 'Activo',\r\n            classNames: ['badge badge-pill badge-danger  m-3 mb-3']\r\n        }\r\n      ]\r\n    },\r\n\r\n    {\r\n      name: 'Opciones',\r\n      cell: (row) => [\r\n        <Link\r\n          className=\"btn btn-outline-primary mx-1\"\r\n          to={`/editCategoria/${row.id}`}\r\n        // onClick={() => alert(row.id)}\r\n        >\r\n          <span className=\"fa-solid fa-pen-to-square\"></span>\r\n\r\n        </Link>,\r\n\r\n        <button\r\n          className=\"btn btn-danger mx-1\"\r\n          onClick={() => confirmar(row.id,row.nombre)}>\r\n          <span className=\"fa-regular fa-trash-can\"></span>\r\n        </button>,\r\n\r\n      ],\r\n    },\r\n  ]\r\n\r\n\r\n  useEffect(() => {\r\n    const result = Categoria.filter((country) => {\r\n      return country.nombre.toLowerCase().match(search.toLowerCase())\r\n    })\r\n\r\n    setFilteredCategoria(result)\r\n  }, [Categoria, search])\r\n\r\n  return (\r\n    <div className='container-fluid ' >\r\n      <DataTable className='table border table-responsive  '\r\n        defaultSortField=\"idTablaData\"\r\n        title=\"Listado de Categoría\"\r\n        theme='custom'\r\n        columns={columns}\r\n        data={filteredCategoria}\r\n        pagination\r\n        sortIcon={<i className=\"fa-solid fa-sort\"></i>}\r\n        fixedHeader\r\n        fixedHeaderScrollHeight=\"450px\"\r\n        // selectableRows\r\n        selectableRowsHighlight\r\n        highlightOnHover\r\n        actions={[\r\n          <Link className=\"btn btn-sm btn-primary px-5\" to=\"/addCategoria\"> Agregar Categoria</Link>,\r\n          <Link className=\"btn btn-sm btn-outline-secondary px-3\" to=\"/reporteCategoria\"> PDF</Link>,\r\n          <CSVLink data={filteredCategoria} filename={\"Tabla de categoria.csv\"}><button className=\"btn btn-sm btn-outline-secondary px-3\"> CSV</button></CSVLink>,\r\n        ]}\r\n        subHeader\r\n        subHeaderComponent={\r\n          <input\r\n            type=\"text\"\r\n            placeholder=\"Buscar Categoria\"\r\n\r\n           // className=\"form-control\"\r\n             className=\"w-25 form-control\"\r\n\r\n            value={search}\r\n            onChange={(e) => setSearch(e.target.value)}\r\n          />\r\n        }\r\n      />\r\n    </div>\r\n  )\r\n}\r\nexport default TblCategoria\r\n",{"ruleId":"137","severity":1,"message":"138","line":5,"column":34,"nodeType":"139","messageId":"140","endLine":5,"endColumn":40},{"ruleId":"141","replacedBy":"142"},{"ruleId":"143","replacedBy":"144"},{"ruleId":"145","severity":1,"message":"146","line":35,"column":19,"nodeType":"147","endLine":35,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":65,"column":19,"nodeType":"147","endLine":65,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":92,"column":19,"nodeType":"147","endLine":92,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":119,"column":19,"nodeType":"147","endLine":119,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":146,"column":19,"nodeType":"147","endLine":146,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":173,"column":19,"nodeType":"147","endLine":173,"endColumn":52},{"ruleId":"145","severity":1,"message":"146","line":209,"column":19,"nodeType":"147","endLine":209,"endColumn":52},{"ruleId":"137","severity":1,"message":"148","line":73,"column":19,"nodeType":"139","messageId":"140","endLine":73,"endColumn":28},{"ruleId":"137","severity":1,"message":"149","line":73,"column":52,"nodeType":"139","messageId":"140","endLine":73,"endColumn":58},{"ruleId":"150","severity":1,"message":"151","line":82,"column":23,"nodeType":"152","messageId":"153","endLine":82,"endColumn":25},{"ruleId":"154","severity":1,"message":"155","line":82,"column":28,"nodeType":"156","messageId":"157","endLine":82,"endColumn":30},{"ruleId":"150","severity":1,"message":"151","line":82,"column":46,"nodeType":"152","messageId":"153","endLine":82,"endColumn":48},{"ruleId":"154","severity":1,"message":"155","line":82,"column":51,"nodeType":"156","messageId":"157","endLine":82,"endColumn":53},{"ruleId":"150","severity":1,"message":"151","line":82,"column":75,"